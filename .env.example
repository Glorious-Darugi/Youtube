# ─────────────────────────────────────────────────────────────
#  공개 데이터 (필수)
# ─────────────────────────────────────────────────────────────
# YouTube Data API v3 키 (서버에서만 사용 — 브라우저에 노출 안 됨)
# 발급: https://console.cloud.google.com → API/서비스 → 사용자 인증 정보 → API 키
#       그리고 "YouTube Data API v3" 사용 설정
YOUTUBE_API_KEY=

# ─────────────────────────────────────────────────────────────
#  수익(자동) + 비용(수동) 기능 — 아래는 V2용. 안 넣으면 공개 지표만 동작.
# ─────────────────────────────────────────────────────────────

# 로그인 세션 암호화 키 (아무 긴 랜덤 문자열).  생성: openssl rand -base64 32
AUTH_SECRET=

# 구글 OAuth 클라이언트 (Cloud Console → 사용자 인증 정보 → OAuth 클라이언트 ID, 웹 애플리케이션)
#  승인된 리디렉션 URI:  https://<배포주소>/api/auth/callback/google
#                        http://localhost:3000/api/auth/callback/google  (로컬용)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# 수익을 볼 수 있는 이메일 (쉼표로 여러 개). 여기 없는 사람은 로그인해도 접근 불가.
# 채널을 소유한 계정 이메일들을 모두 넣으세요 (예: 두 계정).
ALLOWED_EMAILS=

# Vercel Postgres 연결 (Vercel에서 Postgres를 만들면 자동으로 주입됨 — 로컬 개발 때만 수동 필요)
# POSTGRES_URL=

# (선택) 환율 조회 실패 시 사용할 USD→KRW 기본값
# USDKRW_FALLBACK=1380
